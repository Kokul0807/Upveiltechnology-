PORT=3001

# PostgreSQL connection string
# For local development:
# DATABASE_URL="postgresql://user:password@localhost:5432/upveil?schema=public"
#
# For Vercel Postgres:
# Get this from your Vercel dashboard: Settings → Storage → Databases
DATABASE_URL="postgresql://user:password@host:5432/upveil?schema=public"

# CORS origins (comma-separated)
# For development: http://localhost:5500
# For production: https://upveiltechnology.com
CORS_ORIGIN="http://localhost:5500,https://upveiltechnology.com"

# Admin key for /api/contact endpoints (change this!)
ADMIN_KEY="change-me-to-a-random-string"
